# ============================================================
# TRACK BACKEND — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME="Track Fitness API"
ENVIRONMENT=development       # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
API_V1_PREFIX=/api/v1

# --- MongoDB (Atlas or self-hosted) ---
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=track_db

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SECONDS=30

# --- Estimation Pipeline Thresholds ---
MEMORY_HIGH_CONFIDENCE_THRESHOLD=0.85
MEMORY_LOW_CONFIDENCE_THRESHOLD=0.60

# --- JWT Auth ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# --- Storage ---
STORAGE_BACKEND=local                   # local | s3 (s3 not yet implemented)
STORAGE_LOCAL_ROOT=uploads              # Directory to store uploaded photos
STORAGE_MAX_FILE_SIZE_MB=20
STORAGE_ALLOWED_EXTENSIONS=["jpg","jpeg","png","webp","heic"]
STORAGE_PUBLIC_URL_PREFIX=/uploads      # URL prefix for serving static files
VISION_MAX_IMAGE_DIMENSION=1024         # Max px before resize (GPT-4o input)
