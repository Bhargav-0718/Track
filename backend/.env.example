# ============================================================
# TRACK BACKEND — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME="Track Fitness API"
ENVIRONMENT=development       # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
API_V1_PREFIX=/api/v1

# --- Database ---
POSTGRES_USER=track_user
POSTGRES_PASSWORD=track_password
POSTGRES_DB=track_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://track_user:track_password@localhost:5432/track_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false           # Set true to log all SQL queries

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SECONDS=30

# --- Nutrition Database (INDB — no external API needed) ---
# Run once after DB setup: python scripts/import_nutrition_data.py
NUTRITION_DB_MIN_SIMILARITY=0.15
NUTRITION_DB_HIGH_CONFIDENCE_THRESHOLD=0.45

# --- Estimation Pipeline Thresholds ---
MEMORY_HIGH_CONFIDENCE_THRESHOLD=0.85
MEMORY_LOW_CONFIDENCE_THRESHOLD=0.60

# --- JWT Auth ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# --- Storage (Phase 3) ---
STORAGE_BACKEND=local                   # local | s3 (s3 not yet implemented)
STORAGE_LOCAL_ROOT=uploads              # Directory to store uploaded photos
STORAGE_MAX_FILE_SIZE_MB=20
STORAGE_ALLOWED_EXTENSIONS=["jpg","jpeg","png","webp","heic"]
STORAGE_PUBLIC_URL_PREFIX=/uploads      # URL prefix for serving static files
VISION_MAX_IMAGE_DIMENSION=1024         # Max px before resize (GPT-4o input)
